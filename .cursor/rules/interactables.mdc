---
description: For the Interactable component
globs: 
alwaysApply: false
---
Interactables run on both the client AND the server

Example usage for Interactables:
```cs
public class GymPass : Component
{
  public int Cost = 100;
  private Interactable interactable;

  public override void Awake()
  {
    interactable = Entity.AddComponent<Interactable>();

    // When CanUse returns false, the interactable will be hidden for that player. If you want the player to see feedback on why they can't interact, set .Text and early out in OnInteract. Use your best judgement on which to do. 
    interactable.CanUseCallback += (Player p) => 
    {
      var myPlayer = (MyPlayer)p;
      return !myPlayer.HasGymPass;
    };

    // Runs on both the client and the server
    interactable.OnInteract = (Player p) => 
    {
      if (!Network.IsServer) return;

      // Do action here
    };
  }

  public override void Update()
  {
    if (Network.IsServer) return;

    // You can set the Text in awake if you want, but if it's going to be dynamic it'll need to be in update. Do not try to set text on the server. 
    interactable.Text = $"Buy a gym pass for ${Cost}";
  }
}
```