});
```

### Example 4: Shop with Item Details

```csharp
var gridContent = new GridWindowContent()
{
    Columns = 3,
    Items = shopItems
};

var detailContent = new ElementDisplayWindowContent()
{
    ButtonText = "Purchase",
    ButtonColor = ButtonColor.Green,
    ButtonAction = (element) => PurchaseItem(element.Userdata),
    ItemUpdater = (content) => 
    {
        // Update to show selected item
        if (gridContent.SelectedIndex >= 0 && gridContent.SelectedIndex < gridContent.Items.Count)
        {
            return gridContent.Items[gridContent.SelectedIndex];
        }
        return null;
    }
};

var window = Window.Make(new WindowOptions()
{
    Title = "Shop",
    WindowBackgroundColor = WindowBackgroundColor.Gold,
    Content = new SideCarWindowContent()
    {
        Position = SideCarPosition.Right,
        SideCarSize = new Vector2(500, 600),
        Main = gridContent,
        Side = detailContent
    }
});
```

